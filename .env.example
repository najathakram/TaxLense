# TaxLens — Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real values.

# PostgreSQL connection string.
# Local dev (Docker): postgresql://taxlens:taxlens_dev@localhost:5433/taxlens
# Cloud (Railway/Neon): postgresql://user:pass@host:port/db
DATABASE_URL="postgresql://user:password@localhost:5432/taxlens"

# Anthropic API key — required for AI classification agents (Prompt 4+).
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# NextAuth secret — sign JWT tokens. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-char-secret"

# Google OAuth client ID — from https://console.developers.google.com
AUTH_GOOGLE_ID=""

# Google OAuth client secret — from https://console.developers.google.com
AUTH_GOOGLE_SECRET=""

# Public URL of the app (used for OAuth callbacks and email links)
NEXTAUTH_URL="http://localhost:3000"

# Node.js environment: development | test | production
NODE_ENV="development"

# Log verbosity: error | warn | info | debug
LOG_LEVEL="info"

# Upload storage base directory.
# Local dev: omit (defaults to <cwd>/data/uploads).
# Railway: set to the persistent volume mount path, e.g. /mnt/uploads
# UPLOAD_BASE_DIR="/mnt/uploads"
