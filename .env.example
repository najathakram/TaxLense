# TaxLens — Environment Variables
# Copy to .env and fill in values for local development.
# NEVER commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local dev (Docker): postgresql://taxlens:taxlens_dev@localhost:5433/taxlens
# Railway: postgresql://postgres:<password>@<host>:<port>/railway
DATABASE_URL="postgresql://user:password@localhost:5432/taxlens"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Random secret used to sign JWT tokens. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-char-secret"

# Public URL of the app (used for OAuth callbacks)
AUTH_URL="http://localhost:3000"

# ─── OAuth Providers (optional) ──────────────────────────────────────────────
# Google OAuth — create credentials at https://console.developers.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Anthropic API (Session 4+) ──────────────────────────────────────────────
# Required for AI classification agents
ANTHROPIC_API_KEY=""

# ─── Redis / BullMQ (Session 4+) ─────────────────────────────────────────────
# Required for background job queue
REDIS_URL="redis://localhost:6379"

# ─── Misc ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
