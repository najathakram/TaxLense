// TaxLens — Prisma v7 Schema
// Spec: TaxLens v6 Part 5.1
// Immutability note: Transaction, Classification, AuditEvent have NO @updatedAt.
// DB-level triggers (deny UPDATE/DELETE) deferred to Session 8.
// Classification.is_current flip is managed in application code until Session 8.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url is configured in prisma.config.ts from DATABASE_URL env var
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum EntityType {
  SOLE_PROP
  LLC_SINGLE
  // Phase 2 — S-Corp filing on Form 1120-S, with K-1s per shareholder.
  S_CORP
  // Phase 3 — multi-member LLC (partnership), Form 1065 + K-1s per partner.
  LLC_MULTI
  // Phase 4 — C-Corp, Form 1120 (no K-1).
  C_CORP
  // Reserved for general partnerships (not LLC-wrapped). Stub for now.
  PARTNERSHIP
}

enum AccountingMethod {
  CASH
  ACCRUAL
}

enum TaxYearStatus {
  CREATED
  INGESTION
  CLASSIFICATION
  REVIEW
  LOCKED
  ARCHIVED
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  BROKERAGE
  PAYMENT_PROCESSOR
}

// Account behaviour class. Orthogonal to AccountType (which says "checking
// vs CC vs brokerage"). MONEY_MOVER means the account is a wallet that
// aggregates balance — transfers IN don't pair 1:1 with transfers OUT
// because the wallet itself bridges them. Wise, PayPal, Venmo, Cash App,
// Stripe Balance, Zelle. Treat outflows FROM a money-mover as the real
// COGS/expense; outflows TO a money-mover are wallet top-ups (TRANSFER,
// no pair required). Resolves Atif's Chase→Wise COGS double-counting.
enum AccountKind {
  TRADITIONAL
  MONEY_MOVER
}

enum ParseStatus {
  PENDING
  SUCCESS
  FAILED
  PARTIAL
}

enum ReportKind {
  MASTER_LEDGER
  FINANCIAL_STATEMENTS
  AUDIT_PACKET
  TAX_PACKAGE
}

enum ExtractionPath {
  CSV
  OFX
  PDF_PARSE
  HAIKU_CLEANUP
  VISION_DOC
}

enum ImportSessionStatus {
  IN_PROGRESS
  COMPLETE
  ABORTED
}

enum PipelineRunStatus {
  RUNNING
  DONE
  FAILED
  CANCELLED
}

enum PipelineRunKind {
  // Phase 0.4 placeholder kinds — the deterministic-pipeline buttons each
  // open one of these in a background container so the page-level server
  // action returns within 1s.
  NORMALIZE_MERCHANTS
  MATCH_TRANSFERS
  MATCH_PAYMENTS
  MATCH_REFUNDS
  MERCHANT_AI
  APPLY_RULES
  RESIDUAL_AI
  BULK_CLASSIFY
  AUTO_RESOLVE_STOPS
  // Review-first proposal generation — Sonnet writes a recommendation per
  // pending stop with prior-case context; high-confidence ones auto-apply,
  // the rest land in /review for human approval.
  GENERATE_AI_PROPOSALS
  // Phase 1 — single autonomous-bookkeeper run.
  CPA_AGENT
  // Phase A follow-up — re-extract low-confidence PDFs via Sonnet vision.
  EXTRACT_REPASS
}

// All 9 classification codes + 2 supplementary (spec §3.1)
enum TransactionCode {
  WRITE_OFF
  WRITE_OFF_TRAVEL
  WRITE_OFF_COGS
  MEALS_50
  MEALS_100
  GRAY
  PERSONAL
  TRANSFER
  PAYMENT
  BIZ_INCOME
  NEEDS_CONTEXT
}

enum ClassificationSource {
  AI
  USER
  AI_USER_CONFIRMED
}

enum StopCategory {
  MERCHANT
  TRANSFER
  PERIOD_GAP
  DEPOSIT
  SECTION_274D
  // Same counterparty appears on BOTH sides of the ledger — inflows from
  // person X AND outflows to person X. The two sides are typically classified
  // independently (inflow → NEEDS_CONTEXT $0 income, outflow → Contract Labor
  // 100% deductible) creating an asymmetric "best of both worlds" pattern.
  // The CPA must resolve the relationship: personal P2P / customer-and-refund
  // / contractor (1099 required). One STOP per counterparty groups all txns.
  P2P_ROUNDTRIP
}

enum StopState {
  PENDING
  ANSWERED
  DEFERRED
}

enum ActorType {
  USER
  AI
  SYSTEM
}

enum KnownEntityKind {
  PERSON_PERSONAL
  PERSON_CONTRACTOR
  PERSON_CLIENT
  PATTERN_EXCLUDED
  PATTERN_INCOME
}

enum UserRole {
  SUPER_ADMIN
  CPA
  CLIENT
}

// Document categories per the redesign brief §4.4. STATEMENT is reserved for
// rare hand-uploaded raw statements that don't go through the parser pipeline;
// the canonical statement record is StatementImport.
// Owner relationship to the entity. SHAREHOLDER for S/C-Corp; PARTNER for
// LLC-multi/Partnership; PROPRIETOR for SOLE_PROP/LLC_SINGLE (the taxpayer
// themselves, single record auto-created on profile completion).
enum OwnerRole {
  PROPRIETOR
  SHAREHOLDER
  PARTNER
}

// Form 8879 / engagement letter signature state.
enum SignatureStatus {
  NOT_REQUESTED
  REQUESTED
  SIGNED
  DECLINED
  EXPIRED
}

// Where in the file/return lifecycle the year sits. Tracked separately from
// TaxYearStatus (CREATED → INGESTION → CLASSIFICATION → REVIEW → LOCKED) —
// LOCKED + filing-status fork into the engagement workflow.
enum FilingStatus {
  NOT_STARTED
  ENGAGEMENT_SIGNED
  TAXPAYER_8879_SIGNED
  EFILED
  ACCEPTED_BY_IRS
  REJECTED_BY_IRS
  PAPER_FILED
  REFUND_RECEIVED
  BALANCE_PAID
}

// W-9 collection state per contractor. PENDING_REQUEST → email sent;
// RECEIVED → TIN on file; OVERRIDE_PERSONAL_INFO → CPA explicitly waived
// (e.g., corporation exempt under Reg §1.6049-4(c)(1)(ii)).
enum W9Status {
  NOT_REQUESTED
  REQUESTED
  RECEIVED
  EXEMPT
}

// Document categories per the redesign brief §4.4. STATEMENT is reserved for
// rare hand-uploaded raw statements that don't go through the parser pipeline;
// the canonical statement record is StatementImport.
enum DocumentCategory {
  STATEMENT
  TAX_FORM_RECEIVED
  TAX_FORM_ISSUED
  ENGAGEMENT_LEGAL
  IRS_CORRESPONDENCE
  RECEIPT
  OTHER
}

// ---------------------------------------------------------------------------
// NEXTAUTH V5 MODELS (required by PrismaAdapter)
// "Account" here = OAuth account; financial accounts = FinancialAccount
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash; null for OAuth-only users
  role          UserRole  @default(CLIENT)
  // Soft-suspend flag. False blocks login (auth.ts checks). Defaults to true so
  // existing rows don't have to be backfilled. Super admin can flip via /admin
  // — the row is preserved for audit reconstruction.
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts          Account[]
  sessions          Session[]

  // App relations
  taxYears          TaxYear[]
  financialAccounts FinancialAccount[]
  businessProfiles  BusinessProfile[]
  auditEvents       AuditEvent[]
  // Audit events where THIS user is the CPA actor (impersonating someone else).
  // The taxpayer owner of the changed data is captured by AuditEvent.userId;
  // this relation gives us "every action Najath has taken on any client".
  auditEventsAsCpa     AuditEvent[]       @relation("AuditActorCpa")
  // Audit events where THIS user is the platform super admin actor (e.g.,
  // admin impersonating a CPA who is then editing client data).
  auditEventsAsAdmin   AuditEvent[]       @relation("AuditActorAdmin")
  documents            Document[]         @relation("DocumentOwner")
  documentsUploaded    Document[]         @relation("DocumentUploader")

  // CPA relations
  cpaClients  CpaClient[] @relation("CpaRelation")
  cpaOf       CpaClient[] @relation("ClientRelation")

  // A14 attestations the user (typically CPA) has made
  inactiveMonthAttestations AccountInactiveMonth[]

  // Phase 6 — engagement / filing
  engagementLettersAsCpa EngagementLetter[]    @relation("EngagementLetterCpa")
  filingMilestones       FilingMilestone[]     @relation("FilingMilestoneUser")

  // Phase 7 — per-classification notes authored
  classificationNotes    ClassificationNote[]  @relation("ClassificationNoteAuthor")
}

model CpaClient {
  id           String   @id @default(cuid())
  cpaUserId    String
  clientUserId String
  displayName  String?  // CPA's custom label for this client
  notes        String?
  createdAt    DateTime @default(now())

  cpa    User @relation("CpaRelation",    fields: [cpaUserId],    references: [id], onDelete: Cascade)
  client User @relation("ClientRelation", fields: [clientUserId], references: [id], onDelete: Cascade)

  @@unique([cpaUserId, clientUserId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// RULE VERSION (referenced by TaxYear; must come before TaxYear)
// ---------------------------------------------------------------------------

model RuleVersion {
  id             String   @id @default(cuid())
  effectiveDate  DateTime
  ruleSet        Json     // Minimal in Session 1; full library loaded in Session 8
  summary        String?
  supersededById String?

  supersededBy  RuleVersion?  @relation("Supersession", fields: [supersededById], references: [id])
  supersededFor RuleVersion[] @relation("Supersession")

  taxYears TaxYear[]
  reports  Report[]
}

// ---------------------------------------------------------------------------
// TAX YEAR
// ---------------------------------------------------------------------------

model TaxYear {
  id                 String        @id @default(cuid())
  userId             String
  year               Int
  status             TaxYearStatus @default(CREATED)
  ruleVersionId      String?
  lockedAt           DateTime?
  lockedSnapshotHash String?
  // CPA / user acknowledgements that mute specific risk signals (B-23). Shape:
  // { "INCOME_SHORT": true, "...": "rationale text" }. Mute is opt-in and
  // recorded in an AuditEvent; signals stay visible on the dashboard with
  // an "Acknowledged" badge.
  acceptedRiskOverrides Json?
  createdAt          DateTime      @default(now())

  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleVersion       RuleVersion?           @relation(fields: [ruleVersionId], references: [id])
  businessProfile   BusinessProfile?
  financialAccounts FinancialAccount[]
  accountYearLinks  AccountYearLink[]
  statementImports  StatementImport[]
  transactions      Transaction[]
  merchantRules     MerchantRule[]
  stopItems         StopItem[]
  reports           Report[]
  importSessions    ImportSession[]
  documents         Document[]
  pipelineRuns      PipelineRun[]
  inactiveMonths    AccountInactiveMonth[]

  // Phase 4 — carryforward (this year's PriorYearContext + back-references
  // from any years that consumed THIS year's locked snapshot). Owners
  // attach to BusinessProfile, not TaxYear directly.
  priorYearContext  PriorYearContext?  @relation("PYC_taxYear")
  consumedByContexts PriorYearContext[] @relation("PYC_sourceYear")

  // Phase 6 — engagement / 8879 / filing milestones
  engagementLetter  EngagementLetter?
  form8879          Form8879?
  filingMilestones  FilingMilestone[]

  // Phase 2.3 — 1099 issuance
  w9Submissions     W9Submission[]
  form1099Filings   Form1099Filing[]

  @@unique([userId, year])
}

// ---------------------------------------------------------------------------
// BUSINESS PROFILE (one per TaxYear; answers to the 12 universal questions)
// ---------------------------------------------------------------------------

model BusinessProfile {
  id                    String           @id @default(cuid())
  userId                String
  taxYearId             String           @unique
  naicsCode             String?          // Nullable: filled in Step 2 of wizard
  entityType            EntityType       @default(SOLE_PROP)
  primaryState          String           @default("")
  businessDescription   String?          // Nullable: filled in Step 2 of wizard
  grossReceiptsEstimate Decimal?         @db.Decimal(15, 2) // Nullable: filled in Step 3
  accountingMethod      AccountingMethod @default(CASH)
  // JSONB configs (spec §4.1):
  homeOfficeConfig      Json             @default("{\"has\":false}") // { has, dedicated, officeSqft, homeSqft }
  vehicleConfig         Json             @default("{\"has\":false}") // { has, bizPct }
  inventoryConfig       Json?            // { has, physical, dropship }
  revenueStreams         String[]
  firstYear             Boolean          @default(false)
  draftStep             Int              @default(1)  // Wizard progress persistence
  incomeSources         Json?            // [{ platform, expectedTotal, categories }]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user          User            @relation(fields: [userId],    references: [id], onDelete: Cascade)
  taxYear       TaxYear         @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  knownEntities KnownEntity[]
  trips         Trip[]
  owners        Owner[]
}

// ---------------------------------------------------------------------------
// KNOWN ENTITIES (people & patterns; drives auto-classification)
// ---------------------------------------------------------------------------

model KnownEntity {
  id            String           @id @default(cuid())
  profileId     String
  kind          KnownEntityKind
  displayName   String
  matchKeywords String[]         // Strings to match in transaction descriptions
  defaultCode   TransactionCode?
  notes         String?

  profile BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// TRIP (confirmed business trips; dates drive WRITE_OFF_TRAVEL promotion)
// ---------------------------------------------------------------------------

model Trip {
  id                     String   @id @default(cuid())
  profileId              String
  name                   String
  destination            String
  startDate              DateTime
  endDate                DateTime
  purpose                String
  deliverableDescription String?
  isConfirmed            Boolean  @default(false)

  profile BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// OWNER (Phase 3 follow-up — drives multi-owner K-1 generation)
// ---------------------------------------------------------------------------
// One row per shareholder (S-Corp), partner (LLC-multi / partnership), or
// officer-shareholder (C-Corp). For SOLE_PROP / LLC_SINGLE the model is
// unused; the owner is implicitly the User row. ownership values are
// percent (0-100) and must sum to 100 across owners of the same profile —
// validated at write time.
//
// SSN/EIN / W-2 wages are sensitive personal data; we store ssnLast4 only
// (per IRS K-1 form which only requires the last 4) and treat w2Wages as
// a non-secret figure (it's already on the K-1 itself).
model Owner {
  id           String   @id @default(cuid())
  profileId    String
  /** OFFICER (S-Corp officer-shareholder) | SHAREHOLDER (S-Corp non-officer) |
   *  GENERAL_PARTNER | LIMITED_PARTNER | MEMBER (multi-member LLC) |
   *  PROPRIETOR (sole prop / SMLLC — auto-created from BusinessProfile) */
  kind         String
  /** Display name as it should appear on the K-1. */
  name         String
  /** Email — required for K-1 / engagement letter / 8879 secure-link delivery. */
  email        String?
  /** Last 4 of SSN — full SSN never stored. */
  ssnLast4     String?
  /** EIN if the owner is an entity (e.g., a trust holding S-Corp stock). */
  ein          String?
  /** Ownership %; 0-100. Must sum to 100 across owners of the same profile. */
  ownershipPct Decimal  @db.Decimal(7, 4)
  /** S-Corp officer-shareholder W-2 wages from this corp during the year. */
  w2Wages      Decimal? @db.Decimal(15, 2)
  /** Partnership general-partner guaranteed payments (1065 line 10). */
  guaranteedPayments Decimal? @db.Decimal(15, 2)

  /** Mailing address — K-1 box A recipient, 1099 issuance, engagement
   *  letter mailing. */
  addressLine1 String?
  addressLine2 String?
  city         String?
  stateRegion  String?
  postalCode   String?
  countryCode  String   @default("US")

  /** Capital contribution (cumulative) and distributions during the year —
   *  drive Schedule M-2 / K-1 capital roll-forward. */
  capitalContribution Decimal? @db.Decimal(15, 2)
  distributions       Decimal? @db.Decimal(15, 2)

  /** S-Corp specific: stock + debt basis at start of year (per shareholder).
   *  Source for §1366 / §1367 basis tracking carried forward via
   *  PriorYearContext.shareholderBasis. */
  stockBasis Decimal? @db.Decimal(15, 2)
  debtBasis  Decimal? @db.Decimal(15, 2)

  /** Partnership specific: §704(b) capital balance at year-start (per
   *  partner) + §704(c) built-in gain/loss on contributed property. */
  partnerCapitalStart Decimal? @db.Decimal(15, 2)
  bookTaxDelta        Decimal? @db.Decimal(15, 2)

  /** Free-text CPA notes — capital account roll-forward, special allocations. */
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  profile BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([profileId, kind])
}

// ---------------------------------------------------------------------------
// FINANCIAL ACCOUNT (renamed from spec's "Account" to avoid NextAuth conflict)
// ---------------------------------------------------------------------------

model FinancialAccount {
  id                String      @id @default(cuid())
  userId            String
  // Legacy: each FinancialAccount used to belong to exactly one TaxYear,
  // which broke continuity for multi-year clients (B-21). The new
  // AccountYearLink table represents the same account showing up in
  // multiple years. taxYearId stays for back-compat reads — `pnpm
  // post-deploy` runs the backfill that creates AccountYearLink rows from
  // existing data; once every reader migrates we drop the column.
  taxYearId         String
  type              AccountType
  // Behaviour class — see AccountKind enum. Money-mover wallets (Wise,
  // PayPal, Venmo, Stripe, Cash App, Zelle) aggregate balance and don't
  // require 1:1 transfer pairing. Auto-inferred from `institution` on
  // create via inferAccountKind() but the user can override.
  kind              AccountKind @default(TRADITIONAL)
  institution       String
  mask              String?     // Last 4 digits for display
  nickname          String?
  isPrimaryBusiness Boolean     @default(false)

  user             User                   @relation(fields: [userId],    references: [id], onDelete: Cascade)
  taxYear          TaxYear                @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  statementImports StatementImport[]
  transactions     Transaction[]
  yearLinks        AccountYearLink[]
  inactiveMonths   AccountInactiveMonth[]
}

// ---------------------------------------------------------------------------
// ACCOUNT ↔ TAX YEAR LINK (B-21)
// ---------------------------------------------------------------------------
// Lets one FinancialAccount belong to multiple tax years without forcing
// duplicate rows. Backfilled from existing FinancialAccount.taxYearId by
// scripts/backfill-account-year-links.mjs. New uploads should call
// linkAccountToYear() so the join table stays current.

model AccountYearLink {
  id        String   @id @default(cuid())
  accountId String
  taxYearId String
  // Per-year display overrides — useful when a user renames an account
  // mid-year or closes it. Optional; the FinancialAccount.nickname is the
  // fallback.
  nickname  String?
  isClosed  Boolean  @default(false)
  closedAt  DateTime?
  createdAt DateTime @default(now())

  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  taxYear TaxYear          @relation(fields: [taxYearId], references: [id], onDelete: Cascade)

  @@unique([accountId, taxYearId])
}

// ---------------------------------------------------------------------------
// ACCOUNT INACTIVE MONTH ATTESTATION (A14 coverage assertion)
// ---------------------------------------------------------------------------
// One row per (account, year, month) where the CPA has confirmed there was
// no activity (account closed, dormant, or known to have no transactions).
// Without this, A14 flags any month with no uploaded statement as a gap and
// blocks lock — Atif's BofA had 6 missing months and Wise 5 missing months.
// Some are real gaps (statements need uploading); others are inactive periods
// the CPA can attest to. The attestation is a first-class artifact captured
// in AuditEvent for defensibility.

model AccountInactiveMonth {
  id          String   @id @default(cuid())
  accountId   String
  taxYearId   String   // denormalized for fast assertion query
  year        Int      // e.g. 2025
  month       Int      // 1-12
  reason      String   // free-text explanation, ≥ 10 chars
  attestedBy  String   // userId who confirmed
  attestedAt  DateTime @default(now())

  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  taxYear TaxYear          @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [attestedBy], references: [id])

  @@unique([accountId, year, month])
  @@index([taxYearId])
}

// ---------------------------------------------------------------------------
// STATEMENT IMPORT (one per uploaded file)
// ---------------------------------------------------------------------------

model StatementImport {
  id                   String          @id @default(cuid())
  accountId            String
  taxYearId            String
  sessionId            String?         // Session 9: groups uploads in one client session
  filePath             String
  originalFilename     String
  fileType             String
  institution          String?
  periodStart          DateTime?
  periodEnd            DateTime?
  sourceHash           String
  parseStatus          ParseStatus     @default(PENDING)
  parseConfidence      Float?
  totalInflows         Decimal?        @db.Decimal(15, 2)
  totalOutflows        Decimal?        @db.Decimal(15, 2)
  transactionCount     Int             @default(0)
  reconciliationOk     Boolean?
  reconciliationDelta  Decimal?        @db.Decimal(15, 2)
  parseError           String?
  extractionPath       ExtractionPath?
  extractionConfidence Float?
  aiModel              String?
  aiTokensIn           Int?
  aiTokensOut          Int?
  userNotes            Json?           // { institutionConfirmed, accountPurpose, unusualDeposits, gapExplanation, freeText }
  uploadedAt           DateTime        @default(now())

  account      FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  taxYear      TaxYear          @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  session      ImportSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@unique([accountId, sourceHash])
}

// ---------------------------------------------------------------------------
// IMPORT SESSION (Session 9: groups a batch of uploads + client notes)
// ---------------------------------------------------------------------------

model ImportSession {
  id             String              @id @default(cuid())
  taxYearId      String
  cpaUserId      String?             // CPA who initiated the session, if any
  status         ImportSessionStatus @default(IN_PROGRESS)
  totalApiCalls  Int                 @default(0)
  apiCallLimit   Int                 @default(50)
  notes          String?             // Free-text notes for this upload session
  uploadedAt     DateTime            @default(now())
  closedAt       DateTime?

  taxYear TaxYear           @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  imports StatementImport[]
}

// ---------------------------------------------------------------------------
// PIPELINE RUN — Phase 0.4
// ---------------------------------------------------------------------------
// Persists the state of a long-running pipeline operation (Apply Rules, the
// future CPA agent, etc.) so the page-level server action can return within
// 1s and the client can poll this row instead of waiting on the AI calls
// inside the request lifetime. Replaces the 30s server-action ceiling.
//
// `progress` is freeform JSON intended to carry phase / counter pairs:
//   { phase: "merchant_ai", processed: 12, total: 27, costUsd: 0.41 }
//
// One row per run; never updated in-place from outside the runner. The runner
// is the only writer — readers only read.
//
// Append-only? Effectively yes. We DO update status/progress/finishedAt on
// the runner side, but the row is never deleted; the audit trail is the
// monotonic series of PipelineRun rows for a TaxYear.
model PipelineRun {
  id          String            @id @default(cuid())
  taxYearId   String
  kind        PipelineRunKind
  status      PipelineRunStatus @default(RUNNING)
  progress    Json              @default("{}")
  result      Json?
  lastError   String?
  startedAt   DateTime          @default(now())
  finishedAt  DateTime?
  // Who fired the run; mirrors AuditEvent.actorCpaUserId / actorAdminUserId.
  initiatedByUserId String?
  actorCpaUserId    String?
  actorAdminUserId  String?

  taxYear TaxYear @relation(fields: [taxYearId], references: [id], onDelete: Cascade)

  @@index([taxYearId, startedAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// TRANSACTION (INSERT-only — spec §5.2; NO @updatedAt)
// ---------------------------------------------------------------------------

model Transaction {
  id                   String    @id @default(cuid())
  statementImportId    String?   // Null for synthetic/seed data
  accountId            String
  taxYearId            String
  postedDate           DateTime
  transactionDate      DateTime?
  amountOriginal       Decimal   @db.Decimal(15, 2) // Signed per source convention
  amountNormalized     Decimal   @db.Decimal(15, 2) // Outflows +, inflows - (spec §4.2)
  merchantRaw          String
  merchantNormalized   String?
  descriptionRaw       String?
  idempotencyKey       String    @unique // Hash of (accountId + postedDate + amount + merchantRaw)
  isDuplicateOf        String?
  isTransferPairedWith String?
  isPaymentPairedWith  String?
  isRefundPairedWith   String?
  isSplit              Boolean   @default(false) // true on the parent when its amount is split into child txns
  splitOfId            String?   // set on child rows pointing back to the parent txn
  /**
   * Phase A re-extract cleanup. Set true on rows that the original (low-
   * quality) extraction created but the higher-quality Sonnet vision
   * re-extraction did NOT confirm. Excluded from totals + ledger views.
   * Append-only-friendly: row is kept on disk for audit, just hidden from
   * computation.
   */
  isStale              Boolean   @default(false)
  staleReason          String?
  createdAt            DateTime  @default(now())
  // NO updatedAt — immutable by design

  statementImport  StatementImport?  @relation(fields: [statementImportId], references: [id])
  account          FinancialAccount  @relation(fields: [accountId],         references: [id])
  taxYear          TaxYear           @relation(fields: [taxYearId],          references: [id])

  duplicateOf   Transaction?  @relation("TxDuplicate", fields: [isDuplicateOf],        references: [id])
  duplicateFor  Transaction[] @relation("TxDuplicate")
  transferPair  Transaction?  @relation("TxTransfer",  fields: [isTransferPairedWith], references: [id])
  transferPairs Transaction[] @relation("TxTransfer")
  paymentPair   Transaction?  @relation("TxPayment",   fields: [isPaymentPairedWith],  references: [id])
  paymentPairs  Transaction[] @relation("TxPayment")
  refundPair    Transaction?  @relation("TxRefund",    fields: [isRefundPairedWith],   references: [id])
  refundPairs   Transaction[] @relation("TxRefund")
  splitOf       Transaction?  @relation("TxSplit",     fields: [splitOfId],            references: [id])
  splitChildren Transaction[] @relation("TxSplit")

  classifications Classification[]

  // Spec §5.1 indexes
  @@index([taxYearId, postedDate])
  @@index([accountId, postedDate])
  // Phase A re-extract cleanup: filter stale rows from totals/ledger views
  @@index([taxYearId, isStale])
}

// ---------------------------------------------------------------------------
// CLASSIFICATION (append-only — spec §5.2; NO @updatedAt)
// is_current flip managed in app code; DB trigger added in Session 8
// ---------------------------------------------------------------------------

model Classification {
  id              String               @id @default(cuid())
  transactionId   String
  code            TransactionCode
  scheduleCLine   String?
  businessPct     Int                  // 0–100; use Int not Float per spec
  ircCitations    String[]
  confidence      Float                // 0.0–1.0
  evidenceTier    Int                  // 1–5; Int for numeric comparison (spec §3.4)
  source          ClassificationSource
  reasoning       String?
  substantiation  Json?                // §274(d) attendees/purpose/outcome + freeform tags (spec §12.1, Prompt 6)
  isCurrent       Boolean              @default(true)
  createdAt       DateTime             @default(now())
  createdByUserId String?              // User ID or null when actor is AI/SYSTEM
  // NO updatedAt — append-only by design

  transaction Transaction @relation(fields: [transactionId], references: [id])

  // Phase 7 — CPA notes attached to this classification (append-only).
  cpaNotes    ClassificationNote[]

  // Spec §5.1 index
  @@index([transactionId, isCurrent])
}

// ---------------------------------------------------------------------------
// MERCHANT RULE (one per unique merchant per tax year; output of Agent 1)
// ---------------------------------------------------------------------------

model MerchantRule {
  id                  String          @id @default(cuid())
  taxYearId           String
  merchantKey         String          // Normalized merchant name
  code                TransactionCode
  scheduleCLine       String?
  businessPctDefault  Int             // 0–100
  appliesTripOverride Boolean         @default(false)
  ircCitations        String[]
  evidenceTierDefault Int             // 1–5
  confidence          Float
  reasoning           String?
  requiresHumanInput  Boolean         @default(false)
  humanQuestion       String?
  isConfirmed         Boolean         @default(false)
  originalSample      String?
  totalTransactions   Int             @default(0)
  totalAmount         Decimal         @db.Decimal(15, 2) @default(0)

  taxYear   TaxYear    @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  stopItems StopItem[]

  @@unique([taxYearId, merchantKey])
}

// ---------------------------------------------------------------------------
// STOP ITEM (AI-generated questions requiring user input; spec §9)
// ---------------------------------------------------------------------------

model StopItem {
  id             String       @id @default(cuid())
  taxYearId      String
  merchantRuleId String?
  category       StopCategory
  question       String
  context        Json         // { merchant, count, totalAmount, dateRange, ... }
  transactionIds String[]     // Denormalized array of affected transaction IDs
  state          StopState    @default(PENDING)
  userAnswer     Json?
  answeredAt     DateTime?
  // AI's pre-selected default for the resolution form. Persisted (rather than
  // derived per-render) so a low-confidence Sonnet pass that didn't auto-resolve
  // still leaves a default the user can one-click confirm. Shape mirrors the
  // AiSuggestion union in stops-client.tsx — { kind, choice, confidence, ... }.
  // Set by the auto-resolve flow and by deriveStopsFromAssertions for newly-
  // generated DEPOSIT stops; null when no usable signal is available.
  aiSuggestion   Json?
  // Review-first proposal — the richer recommendation produced by the
  // generateAiProposals flow. Carries the full StopAnswer the AI thinks
  // should be applied, plus per-stop reasoning, confidence, the prior
  // similar cases the AI cited, and the generation run id (so the audit
  // trail ties the proposal back to the run that produced it). Cleared on
  // re-generate or after explicit approval. Distinct from `aiSuggestion`
  // (which is just the radio pre-fill) so the review screen has a
  // dedicated, opinionated payload to render.
  //
  // Shape: {
  //   answer: StopAnswer,           // applied as-is when approved
  //   code: TransactionCode,        // derived for display
  //   businessPct: number,
  //   scheduleCLine: string | null,
  //   confidence: number,
  //   reasoning: string,
  //   priorCases: Array<{
  //     stopId: string,
  //     merchantSnippet: string,
  //     resolvedAs: { code, businessPct, line },
  //     resolvedAt: string,
  //     similarity: number,
  //   }>,
  //   generatedAt: string,
  //   generatedRunId: string,
  //   autoApplied: boolean,         // true when stop was already auto-resolved
  // }
  aiProposal     Json?

  taxYear      TaxYear       @relation(fields: [taxYearId],      references: [id], onDelete: Cascade)
  merchantRule MerchantRule? @relation(fields: [merchantRuleId], references: [id])
}

// ---------------------------------------------------------------------------
// AUDIT EVENT (INSERT-only — spec §5.2; NO @updatedAt)
// ---------------------------------------------------------------------------

model AuditEvent {
  id          String    @id @default(cuid())
  userId      String?
  // When set, the CPA who acted on behalf of `user` (the impersonated client).
  // `userId` remains the taxpayer-owner of the changed data so existing queries
  // and assertions don't change shape; `actorCpaUserId` ADDS the "who actually
  // clicked the button" dimension that the redesigned audit-trail view needs.
  actorCpaUserId   String?
  // When set, the platform super admin who initiated the action (typically by
  // impersonating a CPA). Combined with actorCpaUserId, the audit trail can
  // reconstruct the full impersonation chain: admin → CPA → client.
  // Populated by writeAuditEvent automatically from the cookie context.
  actorAdminUserId String?
  actorType   ActorType
  eventType   String
  entityType  String
  entityId    String?
  beforeState Json?
  afterState  Json?
  rationale   String?
  occurredAt  DateTime  @default(now())
  // NO updatedAt — insert-only by design

  user       User? @relation(fields: [userId],           references: [id])
  actorCpa   User? @relation("AuditActorCpa",   fields: [actorCpaUserId],   references: [id])
  actorAdmin User? @relation("AuditActorAdmin", fields: [actorAdminUserId], references: [id])

  @@index([userId, occurredAt(sort: Desc)])
  @@index([actorCpaUserId, occurredAt(sort: Desc)])
  @@index([actorAdminUserId, occurredAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// REPORT (three V1 output artifacts; spec §10)
// ---------------------------------------------------------------------------

model Report {
  id                      String     @id @default(cuid())
  taxYearId               String
  kind                    ReportKind
  filePath                String
  ruleVersionId           String?
  transactionSnapshotHash String?
  generatedAt             DateTime   @default(now())
  isCurrent               Boolean    @default(true)

  taxYear     TaxYear      @relation(fields: [taxYearId],     references: [id], onDelete: Cascade)
  ruleVersion RuleVersion? @relation(fields: [ruleVersionId], references: [id])
}

// ---------------------------------------------------------------------------
// DOCUMENT — non-statement files attached to a client (and optionally a year)
// Spec: design-brief/redesign-cpa-2026.md §4.4
//
// StatementImport remains the canonical record for parsed bank/card statements
// (it carries reconciliation + extraction telemetry). Document covers everything
// else a CPA accumulates: 1099s in/out, engagement letter, IRS notices, receipts.
// ---------------------------------------------------------------------------

model Document {
  id               String           @id @default(cuid())
  userId           String           // taxpayer (client) the document belongs to
  taxYearId        String?          // optional — null means "applies across years"
  category         DocumentCategory
  title            String
  description      String?
  filePath         String
  originalFilename String
  mimeType         String?
  sizeBytes        Int?
  tags             String[]         @default([])
  // Who actually uploaded — could be the CPA or the client themselves.
  uploadedByUserId String?
  uploadedAt       DateTime         @default(now())
  // For RECEIPT documents: link to the transaction(s) this receipt substantiates.
  // Used by the redesigned ledger to show "✓ Receipt attached" and bump tier.
  linkedTransactionIds String[]     @default([])

  user       User    @relation("DocumentOwner",    fields: [userId],           references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("DocumentUploader", fields: [uploadedByUserId], references: [id])
  taxYear    TaxYear? @relation(fields: [taxYearId], references: [id], onDelete: SetNull)

  @@index([userId, category])
  @@index([taxYearId])
  @@index([uploadedByUserId, uploadedAt(sort: Desc)])
}

// ===========================================================================
// PHASE 4 — CARRYFORWARD ENGINE (PriorYearContext)
// ===========================================================================
//
// One row per TaxYear (created automatically when a TaxYear is locked OR
// when the next year's TaxYear is created). Captures everything the next
// year needs from the prior year's locked snapshot.
//
// sourcePriorYearId nullable — first year for a taxpayer has no source.
// sourceLockedHash captures the prior year's lockedSnapshotHash so we can
// detect drift if the prior year is unlocked-and-relocked (the carryforward
// becomes stale and must be regenerated).

model PriorYearContext {
  id                       String   @id @default(cuid())
  // The year THIS context FEEDS (i.e. the consuming year).
  taxYearId                String   @unique
  // Where the carryforward DATA came FROM (the prior year). Null for first
  // year of a taxpayer's history.
  sourcePriorYearId        String?
  sourceLockedHash         String?
  // §172 NOL carryforward (cumulative). Post-TCJA: no carryback, indefinite
  // carryforward, 80% taxable-income limitation.
  netOperatingLoss         Decimal? @db.Decimal(15, 2)
  // §179 carryover where deduction exceeded business income limit.
  section179Carryover      Decimal? @db.Decimal(15, 2)
  // §469 suspended passive losses.
  passiveLossCarryforward  Decimal? @db.Decimal(15, 2)
  // Capital loss carryforwards — short and long term separated for Schedule D.
  capitalLossShortTerm     Decimal? @db.Decimal(15, 2)
  capitalLossLongTerm      Decimal? @db.Decimal(15, 2)
  // §170(d) charitable carryforward by source year (5-year sunset).
  charitableCarryforward   Json?
  // §53 minimum tax (AMT) credit carryforward.
  amtCreditCarryforward    Decimal? @db.Decimal(15, 2)
  // §199A negative QBI carries forward as 199A loss.
  qbiLossCarryforward      Decimal? @db.Decimal(15, 2)
  // §163(j) interest expense carryforward (excess business interest).
  section163jCarryforward  Decimal? @db.Decimal(15, 2)
  // Per-asset depreciation schedule (basis, method, life, years remaining,
  // accumulated depreciation). Shape: array of { assetId, description, ... }.
  depreciationSchedule     Json?
  // S-Corp shareholder basis (per-owner stock + debt basis).
  shareholderBasis         Json?
  // Partnership outside basis + §704(b) capital per partner.
  partnerCapital           Json?
  // Suspended losses by owner (S-Corp basis-limited; partnership at-risk).
  suspendedLosses          Json?
  computedAt               DateTime @default(now())

  taxYear                  TaxYear  @relation("PYC_taxYear",       fields: [taxYearId],         references: [id], onDelete: Cascade)
  sourcePriorYear          TaxYear? @relation("PYC_sourceYear",    fields: [sourcePriorYearId], references: [id])
}

// ===========================================================================
// PHASE 6 — ENGAGEMENT WORKFLOW (Engagement Letter, Form 8879, Filing Status)
// ===========================================================================

// Engagement letter — captured per TaxYear. CPA drafts → client signs via
// secure link (signing flow uses signatureToken). Signed PDF stored at
// signedPdfPath. Required-but-not-blocking for lock today; gating may be
// promoted later via a setting.
model EngagementLetter {
  id              String          @id @default(cuid())
  taxYearId       String          @unique
  // Markdown body — rendered at PDF time + presented to client.
  bodyMarkdown    String
  cpaUserId       String
  cpaSignedAt     DateTime?
  // Client-side signature flow.
  clientSignedAt  DateTime?
  clientName      String?
  clientEmail     String?
  signatureStatus SignatureStatus @default(NOT_REQUESTED)
  // Token used in the magic-link the client receives. URL-safe random.
  signatureToken  String?         @unique
  signedPdfPath   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  taxYear         TaxYear         @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  cpa             User            @relation("EngagementLetterCpa", fields: [cpaUserId], references: [id])
}

// Form 8879 — IRS e-file signature authorization. Auto-populated from the
// locked Schedule C totals + taxpayer info, then signed by taxpayer.
// Per Pub 1345, §1.3 — must be signed before the ERO transmits the return.
// In our V1 we generate the form; transmission happens externally.
model Form8879 {
  id               String          @id @default(cuid())
  taxYearId        String          @unique
  // Snapshot of return totals — signed by taxpayer affirms these numbers.
  totalIncomeUsd   Decimal         @db.Decimal(15, 2)
  taxableIncomeUsd Decimal         @db.Decimal(15, 2)
  totalTaxUsd      Decimal         @db.Decimal(15, 2)
  refundOrAmtDue   Decimal         @db.Decimal(15, 2)
  // ERO PIN — the EFIN-holder's chosen 5-digit PIN per Pub 1345.
  eroPin           String?
  // Taxpayer self-select PIN — 5 digits, cannot be all zeros (Pub 1345).
  taxpayerPin      String?
  spousePin        String?
  signatureStatus  SignatureStatus @default(NOT_REQUESTED)
  signatureToken   String?         @unique
  signedAt         DateTime?
  signedPdfPath    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  taxYear          TaxYear         @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
}

// Filing status — discrete milestones from 'engagement signed' through
// 'IRS-accepted' to 'refund received'. Append-only history, latest by
// (taxYearId, occurredAt).
model FilingMilestone {
  id           String       @id @default(cuid())
  taxYearId    String
  status       FilingStatus
  occurredAt   DateTime     @default(now())
  recordedBy   String       // userId
  notes        String?
  // External system reference (e.g. Drake software acceptance ID).
  externalRef  String?

  taxYear      TaxYear      @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  user         User         @relation("FilingMilestoneUser", fields: [recordedBy], references: [id])

  @@index([taxYearId, occurredAt(sort: Desc)])
}

// ===========================================================================
// PHASE 2.3 — 1099 ISSUANCE (W-9 capture + 1099-NEC filing tracking)
// ===========================================================================

// W-9 form on file for a contractor recipient. One row per (TaxYear, payee
// name) — the same person paid in 2024 and 2025 has two W-9 rows (W-9 is
// a year-specific snapshot per IRS instructions).

model W9Submission {
  id              String   @id @default(cuid())
  taxYearId       String
  // Payee identification
  payeeName       String
  businessName    String?
  taxClassification String? // "Individual/sole proprietor", "C Corp", etc.
  // TIN — SSN (individual) or EIN (entity). Encrypted at app layer.
  tin             String?
  isEntityCorporation Boolean @default(false)
  isExempt        Boolean  @default(false)
  exemptCode      String?
  // Address
  addressLine1    String?
  addressLine2    String?
  city            String?
  stateRegion     String?
  postalCode      String?
  // Workflow state
  status          W9Status @default(NOT_REQUESTED)
  requestedAt     DateTime?
  receivedAt      DateTime?
  // Captured PDF / image of the signed W-9 (path on disk or storage).
  signedW9Path    String?
  // Contact channel for the request
  payeeEmail      String?
  // Free-text — link to the contractor row in the agent's understanding,
  // override notes, etc.
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  taxYear         TaxYear  @relation(fields: [taxYearId], references: [id], onDelete: Cascade)

  @@unique([taxYearId, payeeName])
  @@index([taxYearId, status])
}

// 1099-NEC filing record — one row per (TaxYear, recipient). Created when
// the CPA approves the candidate list on /years/[year]/1099s.
model Form1099Filing {
  id                 String   @id @default(cuid())
  taxYearId          String
  // Recipient (mirrors W9Submission for snapshot purposes).
  recipientName      String
  recipientTin       String?
  recipientAddress   Json?
  // Box amounts. NEC Box 1 is the typical case (nonemployee comp).
  box1NonemployeeComp Decimal? @db.Decimal(15, 2)
  box4FederalTaxWithheld Decimal? @db.Decimal(15, 2)
  // Filing path: PAPER → 1096 + Copy A mailed; ELECTRONIC → IRIS upload.
  filingPath         String   @default("PAPER")
  filedAt            DateTime?
  // External reference (IRIS submission ID, FIRE acknowledgement, etc.).
  externalAck        String?
  // Source transaction IDs that aggregated to this 1099 — for audit.
  sourceTransactionIds String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  taxYear            TaxYear  @relation(fields: [taxYearId], references: [id], onDelete: Cascade)

  @@unique([taxYearId, recipientName])
  @@index([taxYearId])
}

// ===========================================================================
// PHASE 7 — QUALITY-OF-LIFE: per-classification CPA notes
// ===========================================================================
//
// Free-text notes by the CPA on a specific Classification — separate from
// substantiation (which is the §274(d) record). Surfaced as 💬 indicator
// on ledger row hover. Append-only — edits create a new row.
model ClassificationNote {
  id               String   @id @default(cuid())
  classificationId String
  authorUserId     String
  body             String
  createdAt        DateTime @default(now())

  classification   Classification @relation(fields: [classificationId], references: [id], onDelete: Cascade)
  author           User           @relation("ClassificationNoteAuthor", fields: [authorUserId], references: [id])

  @@index([classificationId, createdAt(sort: Desc)])
}
